# dependencies (cloudflared is cloudflared-linux-amd64)
/node_modules
cloudflared

# config files
config.json
config.yml
src/services/service-account.json
tunnel-credentials.json
frontend/.env.development

# docs (ignore everything except superpowers subtree)
/docs/*
!/docs/superpowers/

# local one-time script (runtime only)
src/one-time/oneTimeFunction.js
src/one-time/oneTimeFunction.local.js
src/one-time/oneTimeFunctions.local.js

# member data (PII)
src/data/detailsList.json
src/data/groupList.json
src/data/instrumentList.json
src/data/permissions.json

# event data (contains user IDs and signup responses)
src/events/active/*.json
src/events/archived/*.json

# lock files
*.lock

# activity logs
logs/

# npm/yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
